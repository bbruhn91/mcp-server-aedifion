# aedifion API credentials (required)
AEDIFION_USERNAME=your-email@example.com
AEDIFION_PASSWORD=your-password

# Or use a pre-obtained bearer token instead of username/password
# AEDIFION_TOKEN=your-bearer-token

# API base URL (optional, defaults to https://api.cloud.aedifion.eu)
AEDIFION_BASE_URL=https://api.cloud.aedifion.eu
